# Environment variables for Autonomous Arbitrage Agent
# Copy this file to .env and fill in the values.

# Agent wallet private key (hex). Leave empty to auto-generate.
AGENT_PRIVATE_KEY=

# Human-readable Sphere Nametag for the agent
AGENT_NAMETAG=arb-agent-01

# Nostr public key (used for P2P negotiation messaging)
AGENT_NOSTR_PUBKEY=

# Network config (defaults to Testnet v2)
# RPC_URL=https://testnet.unicity.network/rpc
# FAUCET_URL=https://testnet.unicity.network/faucet

# Scanning interval in ms (default 8000)
# POLL_INTERVAL=8000

# Economic thresholds
# MIN_ARB_SPREAD=0.005
# MIN_YIELD=0.001
# MAX_EXPOSURE=0.2

# Logging level (info | warn | error | debug)
# LOG_LEVEL=info
